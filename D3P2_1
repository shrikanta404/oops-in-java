import java.util.Scanner;

class Person {
    private String name;
    private int age;

    // Outer class constructor
    Person(String name, int age) {
        this.name = name;
        this.age = age;
    }

    // Non-static inner class
    class Address {
        String city;
        int pinCode;

        Address(String city, int pinCode) {
            this.city = city;
            this.pinCode = pinCode;
        }

        void display() {
            System.out.println("\n--- Person Details ---");
            // Accessing outer class private variables (name, age)
            System.out.println("Name: " + name);
            System.out.println("Age: " + age);
            System.out.println("City: " + city);
            System.out.println("Pin Code: " + pinCode);
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Name: ");
        String n = sc.nextLine();
        System.out.print("Enter Age: ");
        int a = sc.nextInt();
        sc.nextLine(); // Consume newline
        System.out.print("Enter City: ");
        String c = sc.nextLine();
        System.out.print("Enter Pin: ");
        int p = sc.nextInt();

        // Step 1: Create Outer Class object
        Person pObj = new Person(n, a);
        // Step 2: Create Inner Class object using the Outer object
        Person.Address addr = pObj.new Address(c, p);

        addr.display();
    }
}
