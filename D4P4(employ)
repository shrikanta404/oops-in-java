package Employee;
import java.util.Scanner;

public class Salaried {
    public String empName;
    public int empId;
    public int age;
    public String address;
    public double salary;
    public int experience;
    public String deptName;

    public void getdata(Scanner sc) {
        System.out.print("Enter Name: "); empName = sc.nextLine();
        System.out.print("Enter ID: "); empId = sc.nextInt();
        System.out.print("Enter Age: "); age = sc.nextInt();
        sc.nextLine();
        System.out.print("Enter Address: "); address = sc.nextLine();
        System.out.print("Enter Salary: "); salary = sc.nextDouble();
        System.out.print("Enter Experience (years): "); experience = sc.nextInt();
        sc.nextLine();
        System.out.print("Enter Dept: "); deptName = sc.nextLine();
    }

    public void printdata() {
        System.out.println(empName + " (ID: " + empId + ") | Dept: " + deptName + " | Exp: " + experience + " years");
    }
}
